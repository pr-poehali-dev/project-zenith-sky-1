{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing required fields",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": { "error": "name and phone are required" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Submit valid request",
      "method": "POST",
      "path": "/",
      "body": {
        "name": "Тест Тестов",
        "phone": "+7 (999) 123-45-67",
        "product": "wire",
        "diameter": "0.5",
        "volume": "2",
        "comment": "Тестовая заявка"
      },
      "expectedStatus": 200,
      "expectedBody": { "ok": true },
      "bodyMatcher": "partial"
    }
  ]
}
